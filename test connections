    print(f"Sources to test: {len(ALL_SOURCES)}")

    r1 = test_firebase_read(firebase_url, firebase_secret)
    r2 = test_firebase_write(firebase_url, firebase_secret)
    r3 = test_gemini(gemini_api_key)
    r4 = test_urls()

    print("\n" + "=" * 60)
    print("Summary")
    print("=" * 60)
    print(f"  [1] Firebase read:   {'PASS' if r1 else 'FAIL'}")
    print(f"  [2] Firebase write:  {'PASS' if r2 else 'FAIL'}")
    print(f"  [3] Gemini API:      {'PASS' if r3 else 'FAIL'}")
    print(f"  [4] URL fetch:       {'PASS' if r4 else 'FAIL (see above)'}")

    all_passed = all([r1, r2, r3, r4])
    if all_passed:
        print(f"\n{PASS} All tests passed. Safe to deploy scanner.py to GitHub Actions.")
    else:
        print(f"\n{FAIL} One or more tests failed. Fix issues above before deploying.")
        sys.exit(1)


if __name__ == "__main__":
    main()
