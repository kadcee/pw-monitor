# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def check_env():
    missing = []
    for var in ["FIREBASE_DATABASE_URL", "FIREBASE_SECRET", "GEMINI_API_KEY"]:
        if not os.environ.get(var):
            missing.append(var)
    return missing


def fb_read(firebase_url, firebase_secret, path):
    url = f"{firebase_url.rstrip('/')}/{path}.json?auth={firebase_secret}"
    req = urllib.request.Request(url, headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=10) as resp:
        return json.loads(resp.read())


def fb_put(firebase_url, firebase_secret, path, data):
    url = f"{firebase_url.rstrip('/')}/{path}.json?auth={firebase_secret}"
    payload = json.dumps(data).encode("utf-8")
    req = urllib.request.Request(url, data=payload, method="PUT",
                                  headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=10) as resp:
        return json.loads(resp.read())


def fb_delete(firebase_url, firebase_secret, path):
    url = f"{firebase_url.rstrip('/')}/{path}.json?auth={firebase_secret}"
    req = urllib.request.Request(url, method="DELETE")
    req.add_header("Content-Type", "application/json")
    req.add_header("Authorization", f"Bearer {firebase_secret}")
    # Firebase delete: PUT null
    payload = b"null"
    req2 = urllib.request.Request(url, data=payload, method="PUT",
                                   headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req2, timeout=10) as resp:
        return json.loads(resp.read())


# ---------------------------------------------------------------------------
# Test 1: Firebase read
# ---------------------------------------------------------------------------

def test_firebase_read(firebase_url, firebase_secret):
    print("\n[1] Firebase Read")
    try:
        data = fb_read(firebase_url, firebase_secret, "baselines")
        if data is None:
            print(f"  {WARN} Connected but baselines/ is empty. Expected on first run.")
        else:
            count = len(data) if isinstance(data, dict) else "?"
            print(f"  {PASS} Read baselines/ — {count} baseline(s) found.")
        return True
    except urllib.error.HTTPError as e:
        if e.code == 401:
            print(f"  {FAIL} Authentication failed (HTTP 401). Check FIREBASE_SECRET.")
        elif e.code == 403:
            print(f"  {FAIL} Permission denied (HTTP 403). Check Firebase database rules (read: true).")
        else:
            print(f"  {FAIL} HTTP {e.code}: {e.reason}")
        return False
    except Exception as e:
        print(f"  {FAIL} {e}")
        return False


# ---------------------------------------------------------------------------
# Test 2: Firebase write + cleanup
# ---------------------------------------------------------------------------

def test_firebase_write(firebase_url, firebase_secret):
    print("\n[2] Firebase Write")
    test_path = "_test/connection_check"
    test_value = {"status": "ok", "note": "PW Monitor connection test — safe to delete"}
    try:
        fb_put(firebase_url, firebase_secret, test_path, test_value)
        # Verify it was written
        verify = fb_read(firebase_url, firebase_secret, test_path)
        if verify and verify.get("status") == "ok":
            print(f"  {PASS} Wrote and verified test value at {test_path}.")
        else:
            print(f"  {WARN} Write succeeded but read-back did not match.")
        # Clean up
        fb_delete(firebase_url, firebase_secret, test_path)
        print(f"  {PASS} Cleaned up test value.")
        return True
    except urllib.error.HTTPError as e:
        if e.code in (401, 403):
            print(f"  {FAIL} Write permission denied (HTTP {e.code}). Check Firebase database rules (write: true).")
        else:
            print(f"  {FAIL} HTTP {e.code}: {e.reason}")
        return False
    except Exception as e:
        print(f"  {FAIL} {e}")
        return False


# ---------------------------------------------------------------------------
# Test 3: Gemini API
# ---------------------------------------------------------------------------

def test_gemini(gemini_api_key):
    print("\n[3] Gemini API")
    url = (
        "https://generativelanguage.googleapis.com/v1beta/models/"
        f"gemini-2.5-flash-lite:generateContent?key={gemini_api_key}"
    )
    prompt = (
        'Respond with this exact JSON and nothing else: '
        '{"relevant": true, "confidence": "high", "summary": "test ok", '
        '"impact_level": "Low", "category": "Administrative / technical update"}'
    )
    payload = {
        "contents": [{"parts": [{"text": prompt}]}],
        "generationConfig": {"temperature": 0.0, "maxOutputTokens": 100}
    }
    data = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(url, data=data, method="POST",
                                  headers={"Content-Type": "application/json"})
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            result = json.loads(resp.read())
        raw = result["candidates"][0]["content"]["parts"][0]["text"]
        clean = raw.strip().lstrip("```json").lstrip("```").rstrip("```").strip()
        parsed = json.loads(clean)
        if parsed.get("relevant") is True and parsed.get("confidence") == "high":
            print(f"  {PASS} Gemini responded correctly and JSON parsed cleanly.")
            print(f"         Model: gemini-2.5-flash-lite | Response: {clean[:80]}")
        else:
            print(f"  {WARN} Gemini responded but output was unexpected: {clean[:120]}")
        return True
    except urllib.error.HTTPError as e:
        if e.code == 400:
            print(f"  {FAIL} Bad request (HTTP 400). Check GEMINI_API_KEY format.")
        elif e.code == 403:
            print(f"  {FAIL} API key rejected (HTTP 403). Verify key at aistudio.google.com.")
        elif e.code == 429:
            print(f"  {WARN} Rate limited (HTTP 429). Key is valid but free tier limit hit. Retry in 1 minute.")
        else:
            print(f"  {FAIL} HTTP {e.code}: {e.reason}")
        return False
    except json.JSONDecodeError as e:
        print(f"  {WARN} Gemini responded but JSON parsing failed: {e}")
        print(f"         Raw response: {raw[:200]}")
        return False
    except Exception as e:
        print(f"  {FAIL} {e}")
        return False


# ---------------------------------------------------------------------------
# Test 4: URL fetch for all 25 sources
# ---------------------------------------------------------------------------

def test_urls():
    print(f"\n[4] URL Fetch — all {len(ALL_SOURCES)} sources")
    results = []
    for source in ALL_SOURCES:
        sid   = source["id"]
        url   = source["url"]
        label = source["label"]
        try:
            req = urllib.request.Request(
                url,
                headers={"User-Agent": "PW-Monitor-Test/3.2 (internal compliance tool)"}
            )
            with urllib.request.urlopen(req, timeout=15) as resp:
                status = resp.status
            if status == 200:
                print(f"  {PASS} [{sid}] {label}")
                results.append({"id": sid, "ok": True, "status": status})
            else:
                print(f"  {WARN} [{sid}] {label} — HTTP {status}")
                results.append({"id": sid, "ok": False, "status": status})
        except urllib.error.HTTPError as e:
            print(f"  {FAIL} [{sid}] {label} — HTTP {e.code} {e.reason}")
            results.append({"id": sid, "ok": False, "status": e.code, "error": str(e)})
        except urllib.error.URLError as e:
            print(f"  {FAIL} [{sid}] {label} — URL error: {e.reason}")
            results.append({"id": sid, "ok": False, "status": None, "error": str(e)})
        except Exception as e:
            print(f"  {FAIL} [{sid}] {label} — {e}")
            results.append({"id": sid, "ok": False, "status": None, "error": str(e)})

    passed = sum(1 for r in results if r["ok"])
    failed = [r for r in results if not r["ok"]]
    print(f"\n  URLs reachable: {passed}/{len(ALL_SOURCES)}")
    if failed:
        print(f"  Unreachable ({len(failed)}):")
        for r in failed:
            print(f"    [{r['id']}] status={r.get('status','?')} — {r.get('error','')}")
    return len(failed) == 0


